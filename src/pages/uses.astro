---

<!doctype html>
<html lang='en'>
	<head>
		<BaseHead
			title={pageTitle}
			description={pageDescription}
			image='/images/ogimage.png'
		/>
	</head>
	<RootLayout>
		<div class='flex flex-col w-full gap-6 max-w-4xl'>
			<Header />

			<div class='flex flex-col gap-2'>
				<h1 class='text-5xl md:text-7xl font-medium tracking-tight'>
					{pageTitle}
				</h1>
				<p class='text-lg text-gray-600 dark:text-gray-400 font-medium'>
					{pageDescription}
				</p>
			</div>

			<!-- Devices -->
			<section class='flex flex-col gap-4 mt-8'>
				<h2 class='text-2xl font-medium tracking-tight text-orange-500'>
					Devices
				</h2>
				<div class='grid grid-cols-1 md:grid-cols-2 gap-6'>
					{devicesAndInstruments.map((item) => (
						<div class='flex flex-col gap-2'>
							<h3 class='text-lg font-medium flex items-center gap-2'>
								<span>{item.icon}</span>
								{item.personalName ? (
									<>
										<span class='text-orange-500'>{item.personalName}</span>
										<span class='text-gray-400 dark:text-gray-600'>—</span>
									</>
								) : null}
								<span>{item.name}</span>
							</h3>
							<p class='text-gray-600 dark:text-gray-400 font-medium'>
								{item.description}
							</p>
						</div>
					))}
				</div>
			</section>

			<!-- Development Tools -->
			{development.length > 0 && (
				<section class='flex flex-col gap-4 mt-8'>
					<h2 class='text-2xl font-medium tracking-tight text-orange-500'>
						Development
					</h2>
					<div class='grid grid-cols-1 md:grid-cols-2 gap-6'>
						{development.map((item) => (
							<div class='flex flex-col gap-2'>
								<h3 class='text-lg font-medium flex items-center gap-2'>
									<span>{item.icon}</span>
